# ===========================================
# Noor-ul-Quran - Environment Configuration
# ===========================================
# Copy this file to backend/.env and fill in
# your values. Never commit .env to version
# control.
# ===========================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/noor-ul-quran?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# SMTP (Email - Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Client URL (frontend)
CLIENT_URL=http://localhost:3000

# OpenAI (optional - AI features work in mock mode without this)
OPENAI_API_KEY=sk-proj-your-openai-api-key
